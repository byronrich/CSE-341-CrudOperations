{
  "openapi": "3.0.0",
  "info": {
    "title": "CrudOperations API",
    "version": "1.0.0",
    "description": "API documentation for Pets, Owners, Veggies, and Fruits CRUD operations."
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Local server"
    },
    {
      "url": "https://your-render-url.onrender.com",
      "description": "Render deployment"
    }
  ],
  "paths": {
    "/pets": {
      "get": {
        "tags": ["Pets"],
        "summary": "Get all pets",
        "responses": {
          "200": { "description": "List of pets" }
        }
      },
      "post": {
        "tags": ["Pets"],
        "summary": "Create a new pet",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Pet" }
            }
          }
        },
        "responses": {
          "201": { "description": "Pet created" },
          "400": { "description": "Validation error" }
        }
      }
    },
    "/pets/{id}": {
      "get": {
        "tags": ["Pets"],
        "summary": "Get a pet by ID",
        "parameters": [
          { "name": "id", "in": "path", "required": true }
        ],
        "responses": {
          "200": { "description": "Pet found" },
          "404": { "description": "Pet not found" }
        }
      },
      "put": {
        "tags": ["Pets"],
        "summary": "Update a pet",
        "parameters": [
          { "name": "id", "in": "path", "required": true }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Pet" }
            }
          }
        },
        "responses": {
          "200": { "description": "Pet updated" },
          "404": { "description": "Pet not found" }
        }
      },
      "delete": {
        "tags": ["Pets"],
        "summary": "Delete a pet",
        "parameters": [
          { "name": "id", "in": "path", "required": true }
        ],
        "responses": {
          "200": { "description": "Pet deleted" },
          "404": { "description": "Pet not found" }
        }
      }
    },

