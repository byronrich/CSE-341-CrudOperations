### BASE URL
@baseUrl = http://localhost:8080

############################################################
# 🐾 PETS
############################################################

### Get all pets
GET {{baseUrl}}/pets

### Get one pet by ID
GET {{baseUrl}}/pets/{{petId}}

### Create a new pet
POST {{baseUrl}}/pets
Content-Type: application/json

{
  "name": "Buddy",
  "type": "Dog",
  "age": 4,
  "ownerId": "12345"
}

### Update a pet
PUT {{baseUrl}}/pets/{{petId}}
Content-Type: application/json

{
  "name": "Buddy Updated",
  "type": "Dog",
  "age": 5,
  "ownerId": "12345"
}

### Delete a pet
DELETE {{baseUrl}}/pets/{{petId}}


